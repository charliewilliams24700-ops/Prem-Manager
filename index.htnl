<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prem Manager 26</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
        body { background: #1a1a2e; color: white; }
.screen { display: none; padding: 15px; max-width: 1000px; margin: 0 auto; }
.active { display: block; }
        #menu { text-align: center; padding-top: 80px; }
        h1 { font-size: 2.5rem; color: #00d4ff; margin-bottom: 10px; }
.btn { background: #00d4ff; color: #1a1a2e; border: none; padding: 12px 30px; font-size: 1.1rem; font-weight: bold; border-radius: 8px; cursor: pointer; margin: 5px; }
.btn:hover { background: #00b8e6; }
.btn-small { padding: 8px 15px; font-size: 0.9rem; }
.btn-red { background: #e94560; color: white; }
.teams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px; margin-top: 15px; }
.team-btn { background: #16213e; border: 2px solid #0f3460; padding: 12px; border-radius: 8px; cursor: pointer; text-align: center; }
.team-btn:active { background: #0f3460; }
.dash-header { background: #16213e; padding: 15px; border-radius: 8px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; }
.stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 15px; }
.stat-box { background: #0f3460; padding: 12px; border-radius: 8px; text-align: center; }
.nav-btns { display: flex; gap: 10px; flex-wrap: wrap; }
.squad-container { display: grid; grid-template-columns: 280px 1fr; gap: 15px; }
.player-list,.pitch-container { background: #16213e; padding: 15px; border-radius: 8px; max-height: 70vh; overflow-y: auto; }
.player { background: #0f3460; margin: 5px 0; padding: 8px; border-radius: 6px; display: flex; justify-content: space-between; cursor: pointer; font-size: 0.9rem; }
.player:hover { background: #1a2b4a; }
.player.selected { border: 2px solid #00d4ff; }
.pos-tag { padding: 2px 6px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; margin-left: 5px; }
.pos-GK { background: #f9a825; }.pos-DEF { background: #43a047; }
.pos-MID { background: #1e88e5; }.pos-FWD { background: #e53935; }
.pitch { background: #2d5016; border: 3px solid white; border-radius: 8px; height: 400px; position: relative; margin-bottom: 10px; }
.center-circle { width: 80px; height: 80px; border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); }
.pitch-player { position: absolute; background: #00d4ff; color: #1a1a2e; padding: 4px 8px; border-radius: 15px; font-size: 0.7rem; font-weight: bold; transform: translate(-50%,-50%); text-align: center; min-width: 60px; cursor: pointer; }
.subs-row { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 10px; }
.sub-player { background: #0f3460; padding: 5px 8px; border-radius: 6px; font-size: 0.7rem; cursor: pointer; }
.modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 999; justify-content: center; align-items: center; pointer-events: none; }
.modal.active { display: flex; pointer-events: all; }
.modal-content { background: #16213e; padding: 25px; border-radius: 12px; text-align: center; width: 90%; max-width: 400px; }
.modal input { width: 100%; padding: 12px; margin: 15px 0; border-radius: 8px; border: none; background: #0f3460; color: white; font-size: 1rem; text-align: center; }
select { background: #0f3460; color: white; border: none; padding: 8px; border-radius: 6px; margin-bottom: 10px; }
@media (max-width: 800px) {
   .squad-container { grid-template-columns: 1fr; }
   .pitch { height: 350px; }
}
    </style>
</head>
<body>
    <div id="nameModal" class="modal">
        <div class="modal-content">
            <h2 id="modalTeamName">Welcome Manager!</h2>
            <p>Enter your name:</p>
            <input type="text" id="managerNameInput" placeholder="Your Name" maxlength="20">
            <button class="btn" onclick="confirmName()">Confirm</button>
        </div>
    </div>

    <div id="menu" class="screen active">
        <h1>PREM MANAGER 26</h1>
        <p style="color:#aaa; margin-bottom:30px;">2025-26 Season | Updated April 2026</p>
        <button class="btn" onclick="showScreen('teamSelect')">START GAME</button>
    </div>

    <div id="teamSelect" class="screen">
        <h2>Select Your Team</h2>
        <div class="teams-grid" id="teamsGrid"></div>
        <button class="btn btn-red btn-small" onclick="showScreen('menu')">Back</button>
    </div>

    <div id="dashboard" class="screen">
        <div class="dash-header">
            <div>
                <h2 id="managerTeam">Team</h2>
                <p>Manager: <span id="managerNameText">You</span></p>
            </div>
            <div style="text-align:right;">
                <p>Week: 1</p>
                <p id="formationText">Formation: 4-3-3</p>
            </div>
        </div>
        <div class="stats">
            <div class="stat-box"><h3>Points</h3><p style="font-size:1.8rem;">0</p></div>
            <div class="stat-box"><h3>Position</h3><p style="font-size:1.8rem;">-</p></div>
            <div class="stat-box"><h3>Budget</h3><p style="font-size:1.8rem;">£50m</p></div>
        </div>
        <div class="nav-btns">
            <button class="btn" onclick="showScreen('squad')">Squad / Lineup</button>
            <button class="btn" onclick="alert('Match engine next!')">Play Match</button>
            <button class="btn btn-red btn-small" onclick="showScreen('teamSelect')">Change Team</button>
        </div>
    </div>

    <div id="squad" class="screen">
        <h2>Squad Management</h2>
        <select id="formationSelect" onchange="updateFormation()">
            <option value="4-3-3">4-3-3</option>
            <option value="4-4-2">4-4-2</option>
            <option value="3-5-2">3-5-2</option>
            <option value="4-2-3-1">4-2-3-1</option>
        </select>
        <div class="squad-container">
            <div class="player-list">
                <h3>Full Squad</h3>
                <div id="fullSquad"></div>
            </div>
            <div class="pitch-container">
                <h3>Starting XI <span id="xiCount">(0/11)</span></h3>
                <div class="pitch" id="pitch">
                    <div class="center-circle"></div>
                </div>
                <h4>Subs Bench</h4>
                <div class="subs-row" id="subsBench"></div>
            </div>
        <button class="btn btn-small" onclick="showScreen('dashboard')" style="margin-top:15px;">Back to Dashboard</button>
    </div>

